<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
    <title>EduStreamiX — Payment Required</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Kalam:wght@400;700&family=Nunito:wght@400;600;700;800&family=Permanent+Marker&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="../Style(CSS)/home.css">
    <link rel="stylesheet" href="../Style(CSS)/!payment.css">
</head>
<body>
    <!-- The gradient top-border from home.css applies automatically via body::before -->

    <div class="payment-container">
        <div class="payment-card">
            <!-- Playful elements tying into the 'school/whiteboard' theme -->
            <div class="scribble-1">Wait!</div>
            <div class="scribble-2">★</div>
            
            <div class="lock-icon-wrapper" id="lockIcon">
                🔒
            </div>

            <h1 class="payment-title" id="paymentTitle">Site Locked</h1>
            <p class="payment-desc" id="paymentDesc">Unlock the ultimate learning experience for Grade 12. No distractions, just pure focus!</p>

            <div class="price-badge" id="priceBadge">
                Just ₹10
            </div>

            <button class="pay-btn-modern" id="payButton">
                <span id="btnText">Pay ₹10 Now</span>
                <div class="btn-spinner" id="btnSpinner"></div>
            </button>

            <div class="secure-note">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--ink-blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" fill="var(--board-white)"></path>
                </svg>
                100% Secure Checkout
            </div>
        </div>
    </div>

    <!-- Reusing the full page loader from home.css -->
    <div class="page-loader-overlay" id="pageLoaderOverlay">
        <div class="page-loader-spinner"></div>
        <p class="page-loader-text" id="loaderText">Processing...</p>
    </div>

    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <script src="../Script(JS)/!payment.js"></script>
</body>
</html>
